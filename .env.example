# ===================================================================
# قالب متغيرات البيئة لمشروع أكاديمية التسجيل
# انسخ هذا الملف إلى ".env" ثم املأ القيم الحقيقية.
#   نسخ:  cp .env.example .env   (أو في ويندوز: copy .env.example .env)
# ⚠️  لا تَرفع ملف .env أو key.json إلى Git أبداً (مدرجان في .gitignore)
# ===================================================================

# مسار ملف اعتماد حساب خدمة Google (Service Account JSON).
# يمكن أن يكون مساراً نسبياً أو مطلقاً.
GOOGLE_KEY_PATH=key.json

# اسم ملف Google Sheets الرئيسي المستخدم لتخزين البيانات.
SPREADSHEET_NAME=تسجيل الاكاديمية

# اسم ورقة العمل (Worksheet) الخاصة بالتحضير.
ATTENDANCE_WORKSHEET_NAME=التحضير

# النطاقات المسموح لها بالوصول (CORS) — مفصولة بفواصل بدون مسافات.
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# وضع التصحيح في Flask: 1 لتفعيله، 0 لإيقافه (استخدم 0 في الإنتاج).
FLASK_DEBUG=0

# المنفذ الذي يعمل عليه الخادم.
FLASK_PORT=5000
